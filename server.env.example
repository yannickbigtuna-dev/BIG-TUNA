# ── apps-server environment ──────────────────────────────────────────────────
# Copy this file to `server.env` (same folder) and fill in the values.
# `server.env` is gitignored — never commit real keys.
# Apply changes with:  pm2 restart ecosystem.config.cjs --update-env

# Public site URL — used to build the YES/NO/NEVER links in coaching emails.
PUBLIC_BASE_URL=https://yannickmorgans.ca

# ── AI coaching (Anthropic, Claude Opus 4.8) ────────────────────────────────
# Get from https://console.anthropic.com  →  Settings  →  API keys  →  Create key.
# Starts with "sk-ant-". Requires billing/credits on the Anthropic account.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional — defaults to claude-opus-4-8 if omitted.
ANTHROPIC_MODEL=claude-opus-4-8

# ── Email delivery (Resend) ─────────────────────────────────────────────────
# Get the key from https://resend.com  →  API Keys  →  Create API Key.
# Starts with "re_".
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# The "from" address. Its domain must be VERIFIED in Resend
# (resend.com → Domains → Add Domain → add the DNS records it shows).
# e.g. coach@yannickmorgans.ca
ASSIGNMENTS_FROM_EMAIL=coach@yannickmorgans.ca

# ── Secrets (generate once, then never change) ──────────────────────────────
# Encrypts each user's stored Brightspace password (AES-256-GCM) and signs the
# email action links. If you change these later, existing saved passwords can no
# longer be decrypted (users just re-enter them) and old email links stop working.
# Generate each with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ASSIGNMENTS_CRYPTO_SECRET=
ASSIGNMENTS_ACTION_SECRET=

# ── Optional ────────────────────────────────────────────────────────────────
# Hour (server local time, 0–23) to send the morning coaching email. Default 6.
ASSIGNMENTS_DAILY_HOUR=6
